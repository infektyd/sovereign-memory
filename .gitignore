# Sovereign Memory public boundary

# Local archives and reversible cleanup bins
_archive/
_cleanup-quarantine/
.last_archive
.last_cleanup_quarantine

# Runtime databases, indexes, and model/adaptor artifacts
*.db
*.db-*
*.sqlite
*.sqlite3
*.db-wal
*.db-shm
*.db-journal
*.index
*.faiss
*.fmadapter

# Private/session-heavy vault and logs
codex-vault/
!codex-vault/
codex-vault/*
!codex-vault/schema/
!codex-vault/schema/AGENTS.md
codex-vault/**/*.canvas
logs/
session-extracts/

# Legacy bundles and local downloads
archives/downloads/
archives/legacy-vaults/

# Local plugin build/runtime state
plugins/*/node_modules/
plugins/*/dist/
plugins/*/.env
plugins/*/.playwright-cli/
plugins/.DS_Store

# Private OpenClaw bridge runtime files
openclaw-extension/node_modules/
openclaw-extension/dist/
openclaw-extension/.import-manifest.json
openclaw-extension/*.bak
openclaw-extension/*.day5.*
openclaw-extension/__pycache__/

# Python/runtime caches
engine/venv/
engine/.day5-contamination-backup/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/

# Local config, secrets, and app/editor state
.env
.env.*
!.env.example
.claude/
.DS_Store
._*
.idea/
.vscode/
