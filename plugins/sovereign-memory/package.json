{
  "name": "sovereign-memory-codex-plugin",
  "version": "0.1.0",
  "description": "Local Codex plugin bridge for Sovereign Memory.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && vite build",
    "build:server": "tsc",
    "build:frontend": "vite build",
    "dev:frontend": "vite --host 127.0.0.1",
    "test": "npm run build && node --test tests/*.test.mjs",
    "console": "npm run build && node dist/ui-server.js",
    "design:lint": "npx @google/design.md lint ../../DESIGN.md",
    "test:live:prepare": "npm run build && node tests/live-prepare-task.mjs",
    "smoke:status": "npm run build && node dist/cli.js status",
    "smoke:hook": "npm run build && node dist/hook.js SessionStart < /dev/null"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^5.0.0",
    "vite": "^8.0.10"
  }
}
