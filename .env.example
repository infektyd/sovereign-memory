# Sovereign Memory configuration
# Copy to .env and customize

# Data directory (defaults to ~/.sovereign/, falls back to ~/.openclaw/)
# SOVEREIGN_HOME=~/.sovereign

# Override individual paths (optional — defaults derive from SOVEREIGN_HOME)
# SOVEREIGN_DB_PATH=~/.sovereign/sovereign_memory.db
# SOVEREIGN_FAISS_PATH=~/.sovereign/sovereign_faiss.index
# SOVEREIGN_GRAPH_DIR=~/.sovereign/graphs/
# SOVEREIGN_WRITEBACK_PATH=~/.sovereign/learnings/
# SOVEREIGN_VAULT_PATH=~/obsidian/openClaw/
